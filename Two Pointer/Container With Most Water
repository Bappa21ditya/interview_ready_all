class Solution {
    public int maxArea(int[] height) {

       int left=0;
       int right=height.length-1;
         int area=0;
        while(left<right)
        {

         // store current result  min of left, right tower and lenght between right and left
         // min(left tower, right tower)* length   
        int res=Math.min(height[left],height[right])*(right-left);
        area=Math.max(area,res);
            
        if(height[left]<height[right])
        {
            left++;
        }
        else
        {
            right--;
        }

        }
        return area;
        
    }
}
